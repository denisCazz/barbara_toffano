# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=barbara_toffano

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email mittente (deve essere un dominio verificato in Resend)
FROM_EMAIL=Barbara Toffano <noreply@barbaratoffano.it>
ADMIN_EMAIL=barbara@barbaratoffano.it

# Istruzioni pagamento (HTML consentito, es: <strong>...</strong><br/>...)
BONIFICO_INSTRUCTIONS=Ti invieremo a breve le <strong>coordinate bancarie</strong> per effettuare il bonifico.
POSTEPAY_INSTRUCTIONS=Ti invieremo a breve i <strong>dati Postepay</strong> e le istruzioni per completare il pagamento.

# Admin
ADMIN_PASSWORD=test

# Site URL (senza slash finale)
SITE_URL=https://barbaratoffano.it

# Opzionale: URL video sul mazzo «Le Bambole Lunatiche» (uso se info_url vuoto nei prodotti 5 e 6)
# PRODUCT_BAMBOLE_VIDEO_URL=https://www.youtube.com/watch?v=XXX

# Astro: controlla Origin sui POST dei form (CSRF).
# Dietro proxy lascia commentato/disattivo (default). Solo se sei sicuro degli header del proxy:
# ASTRO_SECURITY_CHECK_ORIGIN=1
