---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}
const { product } = Astro.props;

const typeLabelMap: Record<Product['type'], string> = {
  audio: 'Audio Personale',
  carta: 'Lettura Carte',
  pacchetto: 'Pacchetto',
};
const typeColorMap: Record<Product['type'], string> = {
  audio: 'badge-audio',
  carta: 'badge-carta',
  pacchetto: 'badge-pack',
};
---

<article class="shop-card">
  <div class="card-header">
    <div class="icon-area">{product.icon}</div>
    <div class="card-meta">
      <span class={`type-badge ${typeColorMap[product.type]}`}>{typeLabelMap[product.type]}</span>
      <h3>{product.name}</h3>
    </div>
  </div>

  <p class="desc">{product.description}</p>

  <ul class="details">
    {product.details.map((d) => (
      <li><span class="check">◆</span>{d}</li>
    ))}
  </ul>

  <div class="card-footer">
    <span class="price">€{product.price.toFixed(2)}</span>
    <a href={`/checkout?product=${product.id}`} class="buy-btn">
      Acquista <span class="arr">→</span>
    </a>
  </div>
</article>

<style>
  .shop-card {
    background: var(--card-bg, #fffcf5);
    border: 1px solid rgba(184,133,42,0.2);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .shop-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(184,133,42,0.11);
  }

  /* ── Header: icon + meta ── */
  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(184,133,42,0.13);
  }

  .icon-area {
    font-size: 2rem;
    width: 58px;
    height: 58px;
    border-radius: 14px;
    background: linear-gradient(135deg, #fdf0e0, #f0e2cc);
    border: 1px solid rgba(184,133,42,0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .shop-card:hover .icon-area { transform: scale(1.06); }

  .card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    min-width: 0;
  }

  .type-badge {
    font-family: 'Cinzel', serif;
    font-size: 0.58rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.22rem 0.6rem;
    border-radius: 4px;
    display: inline-block;
    width: fit-content;
    white-space: nowrap;
  }
  .badge-audio {
    background: rgba(192,80,48,0.1);
    color: var(--accent);
    border: 1px solid rgba(192,80,48,0.26);
  }
  .badge-carta {
    background: rgba(184,133,42,0.1);
    color: var(--gold-mid);
    border: 1px solid rgba(184,133,42,0.26);
  }
  .badge-pack {
    background: rgba(80,130,80,0.1);
    color: #4a7a40;
    border: 1px solid rgba(80,130,80,0.22);
  }

  h3 {
    font-size: 1rem;
    color: var(--text);
    letter-spacing: 0.5px;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Body ── */
  .desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 0 1rem;
    flex: 1;
  }

  .details {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .details li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .check {
    color: var(--gold);
    font-size: 0.38rem;
    flex-shrink: 0;
  }

  /* ── Footer: price + CTA ── */
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(184,133,42,0.14);
  }

  .price {
    font-family: 'Cinzel', serif;
    font-size: 1.7rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: -0.5px;
  }

  .buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 1.5rem;
    background: var(--gold);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: background 0.25s, transform 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .buy-btn:hover {
    background: var(--gold-mid);
    transform: translateY(-1px);
  }
  .arr { transition: transform 0.25s; }
  .buy-btn:hover .arr { transform: translateX(4px); }
</style>
