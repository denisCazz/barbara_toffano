---
interface Props {
  title: string;
  description: string;
  icon?: string;
}
const { title, description, icon = '✨' } = Astro.props;
---

<article class="card">
  <div class="card-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <a href="#contatti" class="card-cta">Scopri di più <span class="arr">→</span></a>
</article>

<style>
  .card {
    background: var(--card-bg, #fffcf5);
    border: 1px solid rgba(184,133,42,0.22);
    border-radius: 16px;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-dark), var(--gold), var(--accent-dark));
    opacity: 0;
    transition: opacity 0.35s;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 50px rgba(184,133,42,0.13);
    border-color: rgba(184,133,42,0.42);
  }
  .card:hover::after { opacity: 1; }

  .card-icon {
    font-size: 2.6rem;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fdf0e0, #f5e4cc);
    border: 1.5px solid rgba(184,133,42,0.28);
    margin-bottom: 1.5rem;
    flex-shrink: 0;
    transition: transform 0.3s, border-color 0.3s;
  }
  .card:hover .card-icon {
    transform: scale(1.06);
    border-color: rgba(184,133,42,0.5);
  }

  h3 {
    font-size: 0.88rem;
    color: var(--gold-mid);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  p {
    font-size: 1.02rem;
    color: var(--text-muted);
    line-height: 1.75;
    flex: 1;
    margin: 0 0 1.75rem;
  }

  .card-cta {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding-bottom: 3px;
    border-bottom: 1px solid rgba(192,80,48,0.32);
    transition: color 0.25s, border-color 0.25s;
    margin-top: auto;
  }
  .card-cta:hover {
    color: var(--gold);
    border-bottom-color: rgba(184,133,42,0.5);
  }
  .arr { transition: transform 0.25s; }
  .card-cta:hover .arr { transform: translateX(5px); }
</style>
