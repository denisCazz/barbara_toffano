---
interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
}
const { title, backHref, backLabel } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Admin — Barbara Toffano</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;500;600&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="admin-nav">
      <div class="nav-brand">
        <span class="brand-star">✦</span>
        <span class="brand-name">Admin Panel</span>
      </div>
      <div class="nav-actions">
        <a href="/admin/dashboard" class={`nav-link ${pathname.startsWith('/admin/dashboard') ? 'active' : ''}`}>Ordini</a>
        <a href="/admin/prodotti" class={`nav-link ${pathname.startsWith('/admin/prodotti') ? 'active' : ''}`}>Prodotti</a>
        <form action="/api/admin/logout" method="POST" style="display:inline">
          <button type="submit" class="logout-btn">Esci</button>
        </form>
      </div>
    </nav>

    <main class="admin-main">
      {
        backHref && (
          <div class="back-bar">
            <a href={backHref} class="back-link">← {backLabel || 'Indietro'}</a>
          </div>
        )
      }
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    /* Admin = più leggibile (contrasto e neutral) */
    --a-bg: #0b0d12;
    --a-surface: #121622;
    --a-surface-2: #171c2c;
    --a-border: rgba(255,255,255,0.10);
    --a-text: #eef2ff;
    --a-muted: rgba(238,242,255,0.68);
    --a-accent: #8b5cf6;
    --a-gold: #f2c94c;
    --a-gold-dim: rgba(242,201,76,0.16);
    --a-green: #22c55e;
    --a-orange: #f97316;
    --a-blue: #60a5fa;
    --a-red: #ef4444;
    --a-radius: 10px;
    --a-radius-sm: 6px;
    --a-shadow: 0 10px 30px rgba(0,0,0,0.28);
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--a-bg);
    color: var(--a-text);
    font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  /* Admin leggibile: niente corsivo globale */
  p, li { font-style: normal; }

  h1, h2, h3 {
    font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    color: var(--a-text);
    letter-spacing: 0.2px;
    margin-top: 0;
    font-style: normal;
  }
  h1 { font-size: 1.35rem; }
  h2 { font-size: 1.1rem; }
  h3 { font-size: 0.95rem; }

  /* Nav */
  .admin-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    height: 56px;
    background: rgba(11,13,18,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--a-border);
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .brand-star { color: var(--a-gold); font-size: 1rem; }
  .brand-name {
    font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 0.9rem;
    color: var(--a-text);
    letter-spacing: 0.6px;
    text-transform: uppercase;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .nav-link {
    color: var(--a-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--a-text); }
  .nav-link.active {
    color: var(--a-text);
    font-weight: 600;
    position: relative;
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -18px;
    height: 2px;
    background: var(--a-accent);
    opacity: 0.75;
    border-radius: 2px;
  }
  .logout-btn {
    background: none;
    border: 1px solid var(--a-border);
    color: var(--a-muted);
    padding: 0.35rem 0.9rem;
    border-radius: var(--a-radius-sm);
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .logout-btn:hover { border-color: var(--a-red); color: var(--a-red); }

  .admin-main {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 4rem;
  }

  .back-bar { margin-bottom: 1.5rem; }
  .back-link {
    color: var(--a-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .back-link:hover { color: var(--a-gold); }

  /* Cards */
  .a-card {
    background: var(--a-surface);
    border: 1px solid var(--a-border);
    border-radius: var(--a-radius);
    padding: 1.25rem;
    box-shadow: var(--a-shadow);
  }

  /* Tables */
  .a-table-wrap {
    background: var(--a-surface);
    border: 1px solid var(--a-border);
    border-radius: var(--a-radius);
    overflow: hidden;
    box-shadow: var(--a-shadow);
  }
  .a-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }
  .a-table th,
  .a-table td {
    padding: 0.85rem 0.9rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    vertical-align: middle;
  }
  .a-table thead th {
    text-align: left;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--a-muted);
    background: rgba(255,255,255,0.02);
    white-space: nowrap;
  }
  .a-table tbody tr:hover td {
    background: rgba(139,92,246,0.06);
  }
  .a-table tbody tr:last-child td { border-bottom: none; }
  .a-td-right { text-align: right; }
  .a-td-muted { color: var(--a-muted); }
  .a-link {
    color: var(--a-text);
    text-decoration: none;
    font-weight: 600;
  }
  .a-link:hover { text-decoration: underline; }
  .a-kbd {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.82rem;
    padding: 0.18rem 0.45rem;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    color: var(--a-text);
  }

  /* Toolbar */
  .a-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .a-toolbar h1 { margin: 0; }
  .a-toolbar .left { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; }
  .a-toolbar .right { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }

  /* Small pills */
  .a-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.03);
    font-size: 0.78rem;
    color: var(--a-muted);
    white-space: nowrap;
  }

  /* Status badges */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.7rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .badge-attesa   { background: rgba(249,115,22,0.15); color: var(--a-orange); border: 1px solid rgba(249,115,22,0.3); }
  .badge-lavorazione { background: rgba(96,165,250,0.15); color: var(--a-blue); border: 1px solid rgba(96,165,250,0.3); }
  .badge-completato  { background: rgba(34,197,94,0.15); color: var(--a-green); border: 1px solid rgba(34,197,94,0.3); }
  .badge-annullato   { background: rgba(239,68,68,0.15); color: var(--a-red); border: 1px solid rgba(239,68,68,0.3); }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border-radius: var(--a-radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--a-accent);
    color: white;
  }
  .btn-primary:hover { background: #7c3aed; }
  .btn-gold {
    background: var(--a-gold);
    color: #000;
    font-weight: 600;
  }
  .btn-gold:hover { background: var(--a-gold-dim); color: var(--a-gold); border: 1px solid var(--a-gold); }
  .btn-outline {
    background: transparent;
    color: var(--a-muted);
    border: 1px solid var(--a-border);
  }
  .btn-outline:hover { border-color: var(--a-text); color: var(--a-text); }
  .btn-danger {
    background: rgba(239,68,68,0.15);
    color: var(--a-red);
    border: 1px solid rgba(239,68,68,0.3);
  }
  .btn-danger:hover { background: rgba(239,68,68,0.25); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-full { width: 100%; }
  .btn-lg { padding: 0.85rem 1.75rem; font-size: 1rem; }

  /* Form inputs */
  .a-input, .a-textarea, .a-select {
    width: 100%;
    background: var(--a-surface-2);
    border: 1px solid var(--a-border);
    border-radius: var(--a-radius-sm);
    color: var(--a-text);
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.65rem 0.9rem;
    transition: border-color 0.2s;
    appearance: auto;
  }
  .a-input:focus, .a-textarea:focus, .a-select:focus {
    outline: none;
    border-color: var(--a-accent);
  }
  .a-textarea { resize: vertical; min-height: 90px; }
  .a-label {
    display: block;
    font-size: 0.75rem;
    color: var(--a-muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .form-group { margin-bottom: 1.25rem; }

  /* Alert */
  .a-alert {
    padding: 0.85rem 1rem;
    border-radius: var(--a-radius-sm);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .a-alert-success { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); color: var(--a-green); }
  .a-alert-error   { background: rgba(239,68,68,0.12);  border: 1px solid rgba(239,68,68,0.3);  color: var(--a-red);   }
  .a-alert-info    { background: rgba(96,165,250,0.12); border: 1px solid rgba(96,165,250,0.3); color: var(--a-blue);  }

  /* Grid helpers */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 600px) { .grid-2 { grid-template-columns: 1fr; } }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--a-bg); }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
</style>
