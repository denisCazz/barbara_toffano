---
interface Props {
  title: string;
  description?: string;
  /** Percorso o URL assoluto immagine OG (default /logo.jpeg) */
  image?: string;
  imageAlt?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  keywords?: string;
}

const SITE_DEFAULT =
  (typeof process !== 'undefined' ? process.env.SITE_URL : undefined)?.replace(/\/+$/, '').trim() || '';

function siteOrigin(): URL {
  if (SITE_DEFAULT) return new URL(SITE_DEFAULT.endsWith('/') ? SITE_DEFAULT : `${SITE_DEFAULT}/`);
  if (Astro.site) return Astro.site;
  return new URL(`${Astro.url.origin}/`);
}

const originBase = siteOrigin();
const ogBase = originBase.origin;
const {
  title,
  description = 'Tarologia e lettura delle carte con Barbara Toffano: consulti, carte angeli e oracoli, ThetaHealing, mazzo «Le Bambole Lunatiche». Shop online e percorsi con responso in 48h.',
  image = '/logo.jpeg',
  imageAlt = 'Barbara Toffano — tarologia e lettura carte',
  ogType = 'website',
  noindex = false,
  keywords =
    'tarologia, Barbara Toffano, lettura carte, tarocchi, carte degli angeli, oracoli, ThetaHealing, consulto tarologico, Bambole Lunatiche',
} = Astro.props;

const canonPath = `${Astro.url.pathname}${Astro.url.search}`;
const canonicalURL = new URL(canonPath || '/', originBase.href).href;
const ogImagePath = image.startsWith('http') ? image : `${ogBase}${image.startsWith('/') ? image : `/${image}`}`;
const pageTitleFull = title.includes('Barbara') ? title : `${title} | Barbara Toffano`;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Barbara Toffano" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitleFull}</title>

    <meta property="og:site_name" content="Barbara Toffano" />
    <meta property="og:title" content={pageTitleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:image" content={ogImagePath} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImagePath} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Great+Vibes&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="galaxy" aria-hidden="true">
      <div class="galaxy-base"></div>
      <div class="galaxy-nebulae">
        <span class="neb neb-violet"></span>
        <span class="neb neb-ember"></span>
        <span class="neb neb-brown"></span>
      </div>
      <canvas class="galaxy-stars" id="stars"></canvas>
      <span class="shooting-star"></span>
    </div>
    <slot />
    <script>
      // Mobile nav toggle
      const toggle = document.querySelector('.nav-toggle');
      const menu = document.querySelector('.nav-menu');
      const overlay = document.querySelector('.nav-overlay');

      function openMenu() {
        menu && menu.classList.add('open');
        overlay && overlay.classList.add('visible');
        toggle && toggle.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
      function closeMenu() {
        menu && menu.classList.remove('open');
        overlay && overlay.classList.remove('visible');
        toggle && toggle.classList.remove('active');
        document.body.style.overflow = '';
      }

      toggle && toggle.addEventListener('click', () =>
        menu && menu.classList.contains('open') ? closeMenu() : openMenu(),
      );
      overlay && overlay.addEventListener('click', closeMenu);
      document.querySelectorAll('.nav-menu a').forEach((l) => l.addEventListener('click', closeMenu));

      // Header scroll shadow
      const header = document.querySelector('header');
      function onScroll() {
        header && header.classList.toggle('scrolled', window.scrollY > 24);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Scroll reveal
      const revealObserver = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('visible'); revealObserver.unobserve(e.target); }
        }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

      // Galaxy canvas stars (pause on prefers-reduced-motion)
      const reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const shootingStar = document.querySelector('.shooting-star');
      if (shootingStar instanceof HTMLElement) {
        // pseudo-random delay per page load, no timers needed
        shootingStar.style.animationDelay = `${Math.floor(Math.random() * 10)}s`;
      }

      const canvasEl = document.getElementById('stars');
      if (!reducedMotion && canvasEl instanceof HTMLCanvasElement) {
        const canvas = canvasEl;
        const ctx = canvas.getContext('2d');
        if (ctx) {
          const c2d = ctx;
          const DPR = Math.min(window.devicePixelRatio || 1, 2);
          let w = 0;
          let h = 0;
          let raf = 0;
          let t0 = performance.now();

          let stars: Array<{ x: number; y: number; r: number; a: number; tw: number; sp: number; layer: 0 | 1 | 2 }> = [];

          function resize() {
            w = Math.floor(window.innerWidth);
            h = Math.floor(window.innerHeight);
            canvas.width = Math.floor(w * DPR);
            canvas.height = Math.floor(h * DPR);
            canvas.style.width = `${w}px`;
            canvas.style.height = `${h}px`;
            c2d.setTransform(DPR, 0, 0, DPR, 0, 0);
            const count = Math.max(180, Math.floor((w * h) / 9000));
            stars = Array.from({ length: count }).map(() => {
              /** @type {0|1|2} */
              const layer = (Math.random() < 0.55 ? 2 : Math.random() < 0.6 ? 1 : 0);
              const baseR = layer === 2 ? 1.1 : layer === 1 ? 0.9 : 0.75;
              return {
                x: Math.random() * w,
                y: Math.random() * h,
                r: baseR + Math.random() * (layer === 2 ? 1.3 : 0.8),
                a: 0.25 + Math.random() * 0.6,
                tw: 0.6 + Math.random() * 1.8,
                sp: (layer === 2 ? 0.05 : layer === 1 ? 0.03 : 0.015) + Math.random() * 0.025,
                layer,
              };
            });
          }

          function draw(now: number) {
            const dt = Math.min(50, now - t0);
            t0 = now;
            c2d.clearRect(0, 0, w, h);

            // soft vignette
            const vg = c2d.createRadialGradient(w * 0.5, h * 0.45, 10, w * 0.5, h * 0.45, Math.max(w, h) * 0.75);
            vg.addColorStop(0, 'rgba(255,255,255,0.02)');
            vg.addColorStop(1, 'rgba(0,0,0,0.18)');
            c2d.fillStyle = vg;
            c2d.fillRect(0, 0, w, h);

            for (const s of stars) {
              s.x += s.sp * dt;
              if (s.x > w + 10) s.x = -10;
              const tw = 0.55 + 0.45 * Math.sin((now / 1000) * s.tw + s.y * 0.02);
              const alpha = Math.max(0, Math.min(1, s.a * tw));
              c2d.beginPath();
              c2d.fillStyle = `rgba(255,245,235,${alpha})`;
              c2d.arc(s.x, s.y, s.r, 0, Math.PI * 2);
              c2d.fill();

              // occasional tinted glint
              if (s.layer === 2 && (s.x + s.y) % 13 < 0.2) {
                c2d.beginPath();
                c2d.fillStyle = `rgba(196,181,253,${alpha * 0.35})`;
                c2d.arc(s.x, s.y, s.r * 2.2, 0, Math.PI * 2);
                c2d.fill();
              }
            }

            raf = requestAnimationFrame(draw);
          }

          const onResize = () => resize();
          window.addEventListener('resize', onResize, { passive: true });
          resize();
          raf = requestAnimationFrame(draw);

          // stop on pagehide
          window.addEventListener('pagehide', () => cancelAnimationFrame(raf), { once: true });
        }
      }
    </script>
  </body>
</html>
<style is:global>
  :root {
    /* Palette: viola + marrone + arancione (chiara sui contenuti) */
    --bg: #12081f;
    --bg-2: #180a2a;
    --bg-3: #220f3a;

    /* Surfaces/cards stay light for readability */
    --card-bg: rgba(255, 248, 240, 0.95);
    --text: #2a1830;
    --text-muted: rgba(42, 24, 48, 0.72);
    --text-on-dark: rgba(255, 244, 235, 0.92);

    /* Violet (primary) */
    --accent: #7c3aed;
    --accent-light: #c4b5fd;
    --accent-mid: #5b21b6;
    --accent-dark: #3b0764;

    /* Brown/gold (ritual metal) */
    --gold: #8b5a2b;
    --gold-light: #c39a6a;
    --gold-mid: #6b3f1d;
    --gold-dark: #3d2410;

    /* Ember orange */
    --ember: #ea580c;
    --ember-soft: #fb923c;

    --sage: #6f8a76;
    --glass: rgba(255, 255, 255, 0.74);
    --glass-border: rgba(124, 58, 237, 0.16);
    --gold-glass: rgba(139, 90, 43, 0.10);
    --gold-border: rgba(139, 90, 43, 0.28);
  }

  *, *::before, *::after { box-sizing: border-box; }

  html {
    font-family: 'Lora', Georgia, serif;
    background: var(--bg);
    color: var(--text-on-dark);
    scroll-behavior: smooth;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    min-height: 100vh;
    background: var(--bg);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Cinzel', serif;
    color: var(--gold);
    letter-spacing: 2px;
    line-height: 1.2;
    font-style: normal;
  }

  /* Cursive writing baseline (keep UI controls readable). */
  body { font-style: italic; }
  p, li, .desc, .contact-desc, .about-text p, blockquote, .subtitle, .hero-eyebrow, .card-cta {
    font-style: italic;
    font-weight: 400;
  }
  .nav-menu a,
  .cta-button,
  .filter-btn,
  .buy-btn,
  .wa-btn,
  .yt-btn,
  .logo-text,
  .price,
  button,
  input,
  select,
  textarea {
    font-style: normal;
  }

  .script-font {
    font-family: 'Great Vibes', cursive;
    color: var(--accent);
  }

  /* ── Galaxy background ── */
  .galaxy {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .galaxy-base {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 40%, rgba(91,33,182,0.55) 0%, rgba(46,16,101,0.22) 45%, rgba(0,0,0,0.75) 100%),
      radial-gradient(ellipse 55% 40% at 82% 92%, rgba(234,88,12,0.22) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 20% 8%, rgba(107,63,29,0.22) 0%, transparent 62%),
      radial-gradient(ellipse 85% 65% at 50% 105%, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 70%);
    filter: saturate(1.1) contrast(1.05);
  }
  .galaxy-nebulae {
    position: absolute;
    inset: -45%;
    opacity: 0.9;
    mix-blend-mode: screen;
  }
  .galaxy-nebulae .neb {
    position: absolute;
    width: 90vmax;
    height: 90vmax;
    border-radius: 50%;
    filter: blur(55px);
    opacity: 0.55;
    animation: neb-drift 58s ease-in-out infinite;
    transform: translate3d(0,0,0);
  }
  .galaxy-nebulae .neb-violet {
    left: 8%;
    top: 8%;
    background: radial-gradient(circle at 40% 40%, rgba(196,181,253,0.65) 0%, rgba(91,33,182,0.25) 45%, rgba(0,0,0,0) 70%);
    animation-duration: 74s;
  }
  .galaxy-nebulae .neb-ember {
    left: 55%;
    top: 35%;
    width: 62vmax;
    height: 62vmax;
    background: radial-gradient(circle at 45% 55%, rgba(251,146,60,0.55) 0%, rgba(234,88,12,0.20) 44%, rgba(0,0,0,0) 72%);
    animation-duration: 62s;
    animation-direction: reverse;
  }
  .galaxy-nebulae .neb-brown {
    left: 18%;
    top: 52%;
    width: 78vmax;
    height: 78vmax;
    background: radial-gradient(circle at 55% 45%, rgba(107,63,29,0.42) 0%, rgba(61,36,16,0.16) 45%, rgba(0,0,0,0) 72%);
    animation-duration: 86s;
  }
  @keyframes neb-drift {
    0%   { transform: translate3d(-2%, -1%, 0) scale(1);   opacity: 0.48; }
    50%  { transform: translate3d(3%,  2%, 0)  scale(1.06); opacity: 0.62; }
    100% { transform: translate3d(-2%, -1%, 0) scale(1);   opacity: 0.48; }
  }
  .galaxy-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.92;
  }
  .shooting-star {
    position: absolute;
    top: 18%;
    left: -30%;
    width: 220px;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0), rgba(196,181,253,0.85), rgba(251,146,60,0.55), rgba(255,255,255,0));
    filter: drop-shadow(0 0 10px rgba(196,181,253,0.35));
    opacity: 0;
    transform: rotate(18deg);
    animation: shoot 12.5s ease-in-out infinite;
  }
  @keyframes shoot {
    0%, 70% { opacity: 0; transform: translate3d(0,0,0) rotate(18deg); }
    74%     { opacity: 0.85; }
    82%     { opacity: 0; transform: translate3d(165vw, 65vh, 0) rotate(18deg); }
    100%    { opacity: 0; transform: translate3d(165vw, 65vh, 0) rotate(18deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .galaxy-nebulae .neb { animation: none; }
    .shooting-star { display: none; }
  }

  /* Mobile: keep animated nebulae always covering viewport */
  @media (max-width: 768px) {
    .galaxy-nebulae { inset: -60%; }
    .galaxy-nebulae .neb {
      width: 110vmax;
      height: 110vmax;
      filter: blur(65px);
      opacity: 0.6;
    }
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--bg-2); }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(var(--gold-dark), var(--accent-dark));
    border-radius: 3px;
  }
  ::selection { background: var(--gold); color: #fff; }

  /* ── Layout ── */
  .container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* ── Navigation ── */
  header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(18, 8, 31, 0.52);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--gold-border);
    transform: translateZ(0);
    transition: box-shadow 0.35s ease;
  }
  header.scrolled {
    box-shadow: 0 2px 28px rgba(44,31,20,0.13);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.25rem;
    max-width: 1180px;
    margin: 0 auto;
  }
  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    z-index: 1001;
    position: relative;
  }
  .logo-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--gold);
    object-fit: cover;
    box-shadow: 0 0 12px rgba(138,101,32,0.18);
  }
  .logo-text {
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gold);
    white-space: nowrap;
  }

  /* Desktop nav links */
  .nav-menu ul {
    display: flex;
    gap: 1.8rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-menu a {
    color: rgba(255, 244, 235, 0.72);
    text-decoration: none;
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.25s;
    position: relative;
    padding-bottom: 3px;
  }
  .nav-menu a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1px;
    background: var(--gold);
    transition: width 0.3s ease;
  }
  .nav-menu a:hover { color: var(--ember-soft); }
  .nav-menu a:hover::after { width: 100%; }

  .nav-menu a.shop-link {
    color: var(--text-on-dark);
    border: 1px solid var(--gold-border);
    padding: 0.35rem 1rem;
    border-radius: 2rem;
    transition: all 0.25s;
  }
  .nav-menu a.shop-link::after { display: none; }
  .nav-menu a.shop-link:hover {
    background: rgba(234, 88, 12, 0.18);
    color: var(--ember-soft);
    border-color: rgba(234, 88, 12, 0.45);
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    z-index: 1001;
    position: relative;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ember-soft);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .nav-toggle.active span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-toggle.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-toggle.active span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Overlay */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.58);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .nav-overlay.visible { opacity: 1; }

  /* Mobile nav */
  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-overlay { display: block; }
    .nav-menu {
      position: fixed;
      top: 0; right: -100%;
      width: min(290px, 80vw);
      height: 100vh;
      background: rgba(18, 8, 31, 0.78);
      backdrop-filter: blur(24px);
      border-left: 1px solid var(--gold-border);
      padding: 5.5rem 1.75rem 2rem;
      z-index: 1000;
      transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .nav-menu.open { right: 0; }
    .nav-menu ul {
      flex-direction: column;
      gap: 0;
      align-items: flex-start;
    }
    .nav-menu li {
      width: 100%;
      border-bottom: 1px solid rgba(255, 244, 235, 0.10);
    }
    .nav-menu a {
      display: block;
      padding: 1rem 0;
      font-size: 0.9rem;
      letter-spacing: 2px;
      color: var(--text-on-dark);
    }
    .nav-menu a:hover { color: var(--ember-soft); }
    .nav-menu a.shop-link {
      margin-top: 1rem;
      display: inline-block;
      padding: 0.65rem 1.4rem;
      width: auto;
    }
  }

  /* ── Footer ── */
  footer {
    background: rgba(0, 0, 0, 0.72);
    border-top: 1px solid rgba(255, 244, 235, 0.12);
    padding: 2.5rem 0;
    position: relative;
    z-index: 10;
  }
  .footer-content {
    text-align: center;
    color: rgba(255, 244, 235, 0.62);
    font-size: 0.88rem;
  }
  .footer-logo {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    color: var(--ember-soft);
    margin-bottom: 0.6rem;
    letter-spacing: 3px;
  }
  .footer-content p { margin: 0.25rem 0; }
  .footer-content a { color: var(--accent-light); text-decoration: none; }
  .footer-content a:hover { color: var(--gold-light); }
  .footer-hours {
    margin: 0.15rem 0 0.65rem !important;
    font-family: 'Cinzel', serif;
    font-size: 0.78rem;
    letter-spacing: 1.2px;
    color: rgba(255, 244, 235, 0.88) !important;
  }
  .footer-hours strong {
    color: var(--ember-soft);
    font-weight: 600;
  }

  /* ── Common section styles ── */
  section { position: relative; z-index: 1; }
  section.veil::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(15, 8, 28, 0.52);
    backdrop-filter: blur(2px);
    pointer-events: none;
    z-index: 0;
  }
  section.veil > * {
    position: relative;
    z-index: 1;
  }
  .gold-text { color: var(--gold); }
  .accent-text { color: var(--accent); }

  /* ── Scroll Reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
