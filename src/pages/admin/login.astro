---
export const prerender = false;

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Login — Barbara Toffano</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="login-page">
      <div class="login-card">
        <div class="brand">
          <span class="brand-star">✦</span>
          <h1>Admin Panel</h1>
          <p class="brand-sub">Barbara Toffano</p>
        </div>

        {
          error && (
            <div class="alert alert-error">
              Password errata. Riprova.
            </div>
          )
        }

        <form action="/api/admin/login" method="POST">
          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autofocus
              autocomplete="current-password"
              placeholder="••••••••••"
            />
          </div>
          <button type="submit" class="btn-login">Accedi →</button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body {
    margin: 0;
    background: #0a0a14;
    font-family: 'Inter', sans-serif;
    color: #e0e0f0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background-image: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(90,24,154,0.2) 0%, transparent 70%);
  }

  .login-page { width: 100%; max-width: 360px; }

  .login-card {
    background: rgba(14,14,24,0.9);
    border: 1px solid rgba(212,175,55,0.18);
    border-radius: 14px;
    padding: 2.5rem 2rem;
    backdrop-filter: blur(12px);
  }

  .brand { text-align: center; margin-bottom: 2rem; }
  .brand-star {
    font-size: 2rem;
    color: #d4af37;
    display: block;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 20px rgba(212,175,55,0.4);
  }
  .brand h1 {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: #d4af37;
    letter-spacing: 3px;
    margin: 0 0 0.3rem;
  }
  .brand-sub {
    color: #6868a0;
    font-size: 0.85rem;
    margin: 0;
    letter-spacing: 1px;
  }

  .alert {
    padding: 0.75rem 1rem;
    border-radius: 7px;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }
  .alert-error {
    background: rgba(239,68,68,0.12);
    border: 1px solid rgba(239,68,68,0.3);
    color: #ef4444;
  }

  .form-group { margin-bottom: 1.25rem; }
  label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #7070a0;
    margin-bottom: 0.5rem;
  }
  input[type="password"] {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    color: #e8e8f0;
    font-size: 1.1rem;
    font-family: 'Inter', sans-serif;
    transition: border-color 0.2s;
    letter-spacing: 4px;
  }
  input:focus { outline: none; border-color: rgba(157,78,221,0.6); }

  .btn-login {
    width: 100%;
    padding: 0.9rem;
    background: rgba(212,175,55,0.12);
    border: 1px solid rgba(212,175,55,0.45);
    color: #d4af37;
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s;
    margin-top: 0.5rem;
  }
  .btn-login:hover {
    background: #d4af37;
    color: #000;
    box-shadow: 0 0 25px rgba(212,175,55,0.2);
  }
</style>
