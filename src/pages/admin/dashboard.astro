---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';

export const prerender = false;

const db = getDb();

const statusFilter = Astro.url.searchParams.get('status') || 'all';

const validStatuses = ['in_attesa', 'lavorazione', 'completato', 'annullato'];
const whereClause =
  statusFilter !== 'all' && validStatuses.includes(statusFilter)
    ? `WHERE status = '${statusFilter}'`
    : '';

const [ordersRows] = await db.execute(
  `SELECT id, order_number, customer_name, customer_email, product_name, product_type,
          amount, payment_method, status, created_at
   FROM orders ${whereClause}
   ORDER BY created_at DESC
   LIMIT 100`,
);
const orders = ordersRows as any[];

const [countRows] = await db.execute(
  `SELECT status, COUNT(*) as cnt FROM orders GROUP BY status`,
);
const counts = Object.fromEntries(
  (countRows as any[]).map((r: any) => [r.status, Number(r.cnt)]),
);
const totalCount = Object.values(counts).reduce((a: any, b: any) => a + b, 0);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('it-IT', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}
function badgeClass(status: string) {
  const map: Record<string, string> = {
    in_attesa: 'badge-attesa',
    lavorazione: 'badge-lavorazione',
    completato: 'badge-completato',
    annullato: 'badge-annullato',
  };
  return map[status] || '';
}
function statusLabel(status: string) {
  const map: Record<string, string> = {
    in_attesa: 'In Attesa',
    lavorazione: 'In Lavorazione',
    completato: 'Completato',
    annullato: 'Annullato',
  };
  return map[status] || status;
}
function paymentLabel(m: string) {
  return { paypal: 'PayPal', bonifico: 'Bonifico', postepay: 'Postepay', non_specificato: '—' }[m] || m || '—';
}
---

<AdminLayout title="Dashboard">
  <div class="a-toolbar">
    <div class="left">
      <h1>Ordini</h1>
      <span class="a-pill">Totale: <strong style="color:var(--a-text)">{totalCount}</strong></span>
    </div>
    <div class="right">
      <button type="button" id="cleanup-btn" class="btn btn-outline">Pulisci audio &gt;30g</button>
      <a href="/admin/dashboard" class="btn btn-outline">Aggiorna</a>
    </div>
  </div>

  <div id="cleanup-feedback" class="cleanup-feedback" style="display:none"></div>

  <!-- Stats -->
  <div class="stats">
    <a class={`stat ${statusFilter === 'all' ? 'active' : ''}`} href="/admin/dashboard?status=all">
      <div class="v">{totalCount}</div>
      <div class="k">Tutti</div>
    </a>
    <a class={`stat ${statusFilter === 'in_attesa' ? 'active' : ''}`} href="/admin/dashboard?status=in_attesa">
      <div class="v v-attesa">{counts['in_attesa'] || 0}</div>
      <div class="k">In attesa</div>
    </a>
    <a class={`stat ${statusFilter === 'lavorazione' ? 'active' : ''}`} href="/admin/dashboard?status=lavorazione">
      <div class="v v-lav">{counts['lavorazione'] || 0}</div>
      <div class="k">Lavorazione</div>
    </a>
    <a class={`stat ${statusFilter === 'completato' ? 'active' : ''}`} href="/admin/dashboard?status=completato">
      <div class="v v-comp">{counts['completato'] || 0}</div>
      <div class="k">Completati</div>
    </a>
    <a class={`stat ${statusFilter === 'annullato' ? 'active' : ''}`} href="/admin/dashboard?status=annullato">
      <div class="v v-ann">{counts['annullato'] || 0}</div>
      <div class="k">Annullati</div>
    </a>
  </div>

  {
    orders.length === 0 ? (
      <div class="a-card empty-state">
        <p class="a-td-muted" style="margin:0">Nessun ordine trovato.</p>
      </div>
    ) : (
      <div class="a-table-wrap">
        <table class="a-table is-stack-mobile">
          <thead>
            <tr>
              <th>Ordine</th>
              <th>Cliente</th>
              <th>Prodotto</th>
              <th>Pagamento</th>
              <th class="a-td-right">Importo</th>
              <th>Stato</th>
              <th>Data</th>
              <th class="a-td-right">Apri</th>
            </tr>
          </thead>
          <tbody>
            {orders.map((o) => (
              <tr>
                <td data-label="Ordine"><span class="a-kbd">{o.order_number}</span></td>
                <td data-label="Cliente" class="cell-block">
                  <div style="font-weight:600">{o.customer_name}</div>
                  <div class="a-td-muted" style="font-size:.85rem;word-break:break-word">{o.customer_email}</div>
                </td>
                <td data-label="Prodotto" class="cell-block">
                  <div style="font-weight:600">{o.product_name}</div>
                  <div class="a-td-muted" style="font-size:.85rem">{o.product_type}</div>
                </td>
                <td data-label="Pagamento"><span class="a-pill">{paymentLabel(o.payment_method)}</span></td>
                <td data-label="Importo" class="a-td-right" style="font-weight:700">€{Number(o.amount).toFixed(2)}</td>
                <td data-label="Stato"><span class={`badge ${badgeClass(o.status)}`}>{statusLabel(o.status)}</span></td>
                <td data-label="Data" class="a-td-muted">{formatDate(o.created_at)}</td>
                <td class="a-td-right cell-actions"><a class="btn btn-outline" href={`/admin/ordine/${o.id}`}>Apri</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>

<script>
  const btn = document.getElementById('cleanup-btn') as HTMLButtonElement | null;
  const feedback = document.getElementById('cleanup-feedback') as HTMLDivElement | null;

  function showFeedback(msg: string, kind: 'ok' | 'err' | 'info') {
    if (!feedback) return;
    feedback.textContent = msg;
    feedback.className = `cleanup-feedback cleanup-${kind}`;
    feedback.style.display = 'block';
    if (kind !== 'err') {
      window.setTimeout(() => { feedback.style.display = 'none'; }, 6000);
    }
  }

  btn?.addEventListener('click', async () => {
    if (!confirm('Eliminare tutti i file audio piu\' vecchi di 30 giorni? Operazione non reversibile.')) return;
    const originalLabel = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Pulizia in corso...';
    try {
      const res = await fetch('/api/admin/cleanup-audio', { method: 'POST' });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        showFeedback(data.error || `Errore (HTTP ${res.status}).`, 'err');
        return;
      }
      const errs = Array.isArray(data.errors) && data.errors.length
        ? ` ${data.errors.length} errori.`
        : '';
      showFeedback(
        `Pulizia completata: ${data.deletedCount} file eliminati, ${data.dbCleared} record DB aggiornati.${errs}`,
        data.errors?.length ? 'info' : 'ok',
      );
    } catch (err) {
      showFeedback('Errore di rete. Riprova.', 'err');
    } finally {
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  });
</script>

<style>
  .cleanup-feedback {
    margin: 0 0 1rem;
    padding: 0.7rem 1rem;
    border-radius: var(--a-radius-sm);
    font-size: 0.88rem;
    border: 1px solid var(--a-border);
    line-height: 1.5;
  }
  .cleanup-ok  { background: rgba(34,197,94,0.10);  border-color: rgba(34,197,94,0.35);  color: #86efac; }
  .cleanup-err { background: rgba(239,68,68,0.10);  border-color: rgba(239,68,68,0.35);  color: #fca5a5; }
  .cleanup-info{ background: rgba(234,179,8,0.10);  border-color: rgba(234,179,8,0.35);  color: #fde68a; }

  /* mobile-first: stats 2 col, scaling up */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    margin-bottom: 1rem;
  }
  .stat {
    display: block;
    text-decoration: none;
    background: var(--a-surface);
    border: 1px solid var(--a-border);
    border-radius: var(--a-radius);
    padding: 0.75rem 0.9rem;
    box-shadow: var(--a-shadow);
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .stat:active { transform: scale(0.98); }
  .stat:hover { border-color: rgba(139,92,246,0.35); }
  .stat.active { border-color: rgba(139,92,246,0.55); background: rgba(139,92,246,0.10); }
  .v { font-size: 1.4rem; font-weight: 800; color: var(--a-text); line-height: 1; }
  .k { margin-top: 0.35rem; font-size: 0.72rem; color: var(--a-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .v-attesa { color: var(--a-orange); }
  .v-lav { color: var(--a-blue); }
  .v-comp { color: var(--a-green); }
  .v-ann { color: var(--a-red); }

  .empty-state { padding: 1.25rem; }

  @media (min-width: 560px) {
    .stats { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; }
    .stat { padding: 0.9rem 1rem; }
    .v { font-size: 1.5rem; }
    .k { font-size: 0.78rem; }
  }

  @media (min-width: 980px) {
    .stats { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  }
</style>
