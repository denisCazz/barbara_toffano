---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Nuovo prodotto" backHref="/admin/prodotti" backLabel="Prodotti">
  <div class="a-card" style="padding:1.25rem">
    <form action="/api/admin/products/upsert" method="POST" class="form">
      <input type="hidden" name="mode" value="create" />

      <div class="grid">
        <div class="form-group">
          <label class="a-label">Nome</label>
          <input class="a-input" name="name" required />
        </div>

        <div class="form-group">
          <label class="a-label">Prezzo (€)</label>
          <input class="a-input" name="price" type="number" step="0.01" min="0" required />
        </div>

        <div class="form-group">
          <label class="a-label">Categoria (filtri shop)</label>
          <select class="a-select" name="category" required>
            <option value="consulto">Consulto</option>
            <option value="meditazione">Meditazione</option>
            <option value="lettura">Lettura</option>
            <option value="vendita">Vendita</option>
          </select>
        </div>

        <div class="form-group">
          <label class="a-label">Tipo consegna (admin audio)</label>
          <select class="a-select" name="delivery_type" required>
            <option value="audio">Audio</option>
            <option value="carta">Carta</option>
            <option value="pacchetto">Pacchetto</option>
          </select>
        </div>

        <div class="form-group">
          <label class="a-label">Icona (emoji)</label>
          <input class="a-input" name="icon" value="✦" />
        </div>

        <div class="form-group">
          <label class="a-label">Ordine (sort)</label>
          <input class="a-input" name="sort_order" type="number" step="1" value="0" />
        </div>
      </div>

      <div class="form-group">
        <label class="a-label">Descrizione</label>
        <textarea class="a-textarea" name="description" rows="5" required></textarea>
      </div>

      <div class="form-group">
        <label class="a-label">Dettagli (uno per riga)</label>
        <textarea class="a-textarea" name="details" rows="4" placeholder="Es:\nSessione privata\nRiscontro entro 48h"></textarea>
      </div>

      <div class="grid">
        <div class="form-group">
          <label class="a-label">Link “Scopri di più” (opzionale, es. video YouTube)</label>
          <input class="a-input" type="url" name="info_url" placeholder="https://..." />
        </div>
        <div class="form-group">
          <label class="a-label">Testo pulsante link</label>
          <input class="a-input" name="info_label" placeholder="Scopri di più (video sul mazzo)" />
        </div>
      </div>

      <div class="checks">
        <label class="check"><input type="checkbox" name="featured" value="1" /> In evidenza</label>
        <label class="check"><input type="checkbox" name="is_active" value="1" checked /> Attivo</label>
      </div>

      <div class="actions sticky-cta">
        <button class="btn btn-primary btn-full" type="submit">Crea prodotto</button>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .form { display: flex; flex-direction: column; gap: 1rem; }
  .grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .checks { display: flex; flex-direction: column; gap: 0.75rem; }
  .check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: var(--a-tap);
    color: var(--a-text);
    font-size: 0.95rem;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--a-border);
    border-radius: var(--a-radius-sm);
    background: var(--a-surface-2);
  }
  .check input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: var(--a-accent);
  }
  .actions { display: flex; }
  @media (min-width: 720px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .checks { flex-direction: row; gap: 1.25rem; flex-wrap: wrap; }
    .check {
      background: transparent;
      border: none;
      padding: 0;
      color: var(--a-muted);
      font-size: 0.9rem;
    }
    .actions .btn { width: auto; }
  }
</style>

