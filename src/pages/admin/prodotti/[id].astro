---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getProductById } from '../../../lib/products';

export const prerender = false;

const { id } = Astro.params;
const pid = Number(id);
if (!pid) return new Response('Not found', { status: 404 });

const product = await getProductById(pid);
if (!product) return new Response('Prodotto non trovato', { status: 404 });

function detailsText(details: string[]) {
  return (details || []).join('\n');
}
---

<AdminLayout title={`Modifica prodotto`} backHref="/admin/prodotti" backLabel="Prodotti">
  <div class="a-card" style="padding:1.25rem">
    <form action="/api/admin/products/upsert" method="POST" class="form">
      <input type="hidden" name="mode" value="update" />
      <input type="hidden" name="id" value={product.id} />

      <div class="grid">
        <div class="form-group">
          <label class="a-label">Nome</label>
          <input class="a-input" name="name" required value={product.name} />
        </div>

        <div class="form-group">
          <label class="a-label">Prezzo (€)</label>
          <input class="a-input" name="price" type="number" step="0.01" min="0" required value={product.price} />
        </div>

        <div class="form-group">
          <label class="a-label">Categoria (filtri shop)</label>
          <select class="a-select" name="category" required>
            <option value="consulto" selected={product.category === 'consulto'}>Consulto</option>
            <option value="meditazione" selected={product.category === 'meditazione'}>Meditazione</option>
            <option value="lettura" selected={product.category === 'lettura'}>Lettura</option>
            <option value="vendita" selected={product.category === 'vendita'}>Vendita</option>
          </select>
        </div>

        <div class="form-group">
          <label class="a-label">Tipo consegna (admin audio)</label>
          <select class="a-select" name="delivery_type" required>
            <option value="audio" selected={product.delivery_type === 'audio'}>Audio</option>
            <option value="carta" selected={product.delivery_type === 'carta'}>Carta</option>
            <option value="pacchetto" selected={product.delivery_type === 'pacchetto'}>Pacchetto</option>
          </select>
        </div>

        <div class="form-group">
          <label class="a-label">Icona (emoji)</label>
          <input class="a-input" name="icon" value={product.icon} />
        </div>

        <div class="form-group">
          <label class="a-label">Ordine (sort)</label>
          <input class="a-input" name="sort_order" type="number" step="1" value={product.sort_order} />
        </div>
      </div>

      <div class="form-group">
        <label class="a-label">Descrizione</label>
        <textarea class="a-textarea" name="description" rows="5" required>{product.description}</textarea>
      </div>

      <div class="form-group">
        <label class="a-label">Dettagli (uno per riga)</label>
        <textarea class="a-textarea" name="details" rows="4">{detailsText(product.details)}</textarea>
      </div>

      <div class="checks">
        <label class="check"><input type="checkbox" name="featured" value="1" checked={product.featured} /> In evidenza</label>
        <label class="check"><input type="checkbox" name="is_active" value="1" checked={product.is_active} /> Attivo</label>
      </div>

      <div class="actions">
        <button class="btn btn-primary" type="submit">Salva</button>
      </div>
    </form>
  </div>
</AdminLayout>

<style>
  .form{display:flex;flex-direction:column;gap:1rem}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .checks{display:flex;gap:1.25rem;flex-wrap:wrap}
  .check{display:flex;gap:.5rem;align-items:center;color:var(--a-muted);font-size:.9rem}
  .actions{display:flex;justify-content:flex-end}
  @media(max-width:720px){.grid{grid-template-columns:1fr}}
</style>

