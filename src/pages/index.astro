---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ShopCard from '../components/ShopCard.astro';
import { products } from '../data/products';

const featuredProducts = products.filter((p) => p.featured);
---

<Layout title="Barbara Toffano - Astrologia e Magia">
  <header>
    <div class="nav-inner">
      <a href="#home" class="logo-container">
        <img src="/logo.jpeg" alt="Barbara Toffano" class="logo-img" />
        <span class="logo-text">Barbara Toffano</span>
      </a>
      <button class="nav-toggle" aria-label="Apri menu">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-overlay"></div>
      <nav class="nav-menu">
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#servizi">Servizi</a></li>
          <li><a href="#shop">Shop</a></li>
          <li><a href="#chi-sono">Chi Sono</a></li>
          <li><a href="#contatti">Contatti</a></li>
          <li><a href="/shop" class="shop-link">✦ Shop</a></li>
        </ul>
      </nav>
    </div>
  </header>

	<main>
        <section id="home" class="hero">
            <div class="hero-aurora"></div>
            <div class="hero-particles" aria-hidden="true">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
            </div>
            <div class="hero-content">
                <p class="hero-eyebrow fade-in">✦ Astrologia · Tarocchi · Magia ✦</p>
                <h1 class="fade-in-delay">Scopri il tuo<br /><span class="gold-text">Destino</span></h1>
                <p class="subtitle script-font fade-in-delay-2">Strumenti antichi per tempi moderni</p>
                <div class="hero-actions fade-in-delay-3">
                    <a href="#servizi" class="cta-button">Esplora i Servizi</a>
                    <a href="/shop" class="cta-button cta-outline">Vai allo Shop</a>
                </div>
            </div>
            <div class="scroll-hint" aria-hidden="true"><div class="scroll-line"></div></div>
        </section>

        <div class="mystic-divider"></div>

        <section id="servizi" class="services reveal veil">
            <div class="container">
                <h2>I Miei Servizi</h2>
                <p class="section-subtitle script-font">Strumenti antichi per fare chiarezza</p>
                <div class="grid">
                    <ServiceCard 
                        title="Consulto Privato" 
                        description="Uno spazio riservato per mettere ordine nei pensieri, ascoltare i segnali e scegliere con più lucidità."
                        icon="🔮"
                    />
                    <ServiceCard 
                        title="Meditazione + Guarigione Energetica" 
                        description="Meditazione guidata con ThetaHealing per alleggerire, riequilibrare e ritrovare centratura."
                        icon="🪷"
                    />
                    <ServiceCard 
                        title="Lettura delle Rune" 
                        description="Un linguaggio antico per capire il presente e ricevere un'indicazione concreta sul passo successivo."
                        icon="ᚱ"
                    />
                    <ServiceCard 
                        title="Carte degli Angeli" 
                        description="Messaggi di luce e conforto per ritrovare fiducia e serenità nelle scelte del cuore."
                        icon="👼"
                    />
                    <ServiceCard 
                        title="Lettura degli Oracoli" 
                        description="Risposte e conferme quando ti serve direzione: energia del momento e consiglio pratico."
                        icon="🌙"
                    />
                </div>
            </div>
        </section>

        <div class="mystic-divider-reverse"></div>

        <section id="shop" class="shop-section reveal veil">
            <div class="container">
                <h2>Lo Shop Mistico</h2>
                <p class="section-subtitle script-font">Percorsi, letture e carte con consegna</p>
                <div class="shop-grid">
                    {featuredProducts.map((p) => <ShopCard product={p} />)}
                </div>
                <div class="shop-cta-row">
                    <a href="/shop" class="cta-button">Vedi tutti i prodotti →</a>
                </div>
            </div>
        </section>

        <div class="mystic-divider"></div>

        <section id="chi-sono" class="about reveal veil">
            <div class="container">
                <h2>Chi Sono</h2>
                <div class="about-card">
                    <div class="about-text">
                        <p class="about-intro script-font">Ciao sono Barbara,</p>
                        <p>La mia curiosità abbinata al mio dono mi hanno portato a studiare nuovi percorsi di vita....</p>
                        <p>All'inizio tante paure...difficoltà...dubbi....dolore.....poi la Rinascita.....ed eccomi per condividere con voi questo meraviglioso viaggio......</p>
                        <div class="about-actions">
                            <a href="https://www.youtube.com/@Barbara_toffano" target="_blank" rel="noopener" class="yt-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M21.543 6.498C22 8.28 22 12 22 12s0 3.72-.457 5.502c-.254.985-.997 1.76-1.938 2.022C17.896 20 12 20 12 20s-5.893 0-7.605-.476c-.945-.266-1.687-1.04-1.938-2.022C2 15.72 2 12 2 12s0-3.72.457-5.502c.254-.985.997-1.76 1.938-2.022C6.107 4 12 4 12 4s5.896 0 7.605.476c.945.266 1.687 1.04 1.938 2.022zM10 15.5l6-3.5-6-3.5v7z"/></svg>
                                Visita il canale YouTube
                            </a>
                        </div>
                    </div>
                    <div class="about-visual">
                        <div class="orb-ring"></div>
                        <div class="orb-ring-2"></div>
                        <div class="orb-inner">🔮</div>
                    </div>
                </div>
            </div>
        </section>

        <div class="mystic-divider"></div>

        <section id="contatti" class="contact reveal veil">
            <div class="container">
                <h2>Contattami</h2>
                <p class="section-subtitle script-font">Sono qui per te</p>
                <div class="contact-wrap">
                    <div class="contact-altar">
                        <span class="altar-corner c1">✦</span>
                        <span class="altar-corner c2">✦</span>
                        <span class="altar-corner c3">✦</span>
                        <span class="altar-corner c4">✦</span>

                        <div class="altar-left">
                            <div class="avatar-ring">
                                <img src="/logo.jpeg" alt="Barbara Toffano" class="avatar" />
                            </div>
                            <div class="altar-name">Barbara Toffano</div>
                            <div class="altar-sub script-font">Scrivimi e ti rispondo personalmente</div>
                            <div class="badge-row">
                                <span class="meta-badge">Risposta entro 24h</span>
                                <span class="meta-badge meta-badge-2">Lun–Sab · 9–19</span>
                            </div>
                        </div>

                        <div class="altar-right">
                            <p class="contact-desc">
                                Per informazioni sui servizi, prenotazioni o semplicemente per conoscerci.
                                Se senti confusione, partiamo da una domanda semplice e la trasformiamo in chiarezza.
                            </p>

                            <a href="https://wa.me/393297813392" target="_blank" rel="noopener" class="wa-btn wa-btn-altar">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.816 9.816 0 0 0 12.04 2m.01 1.67c2.2 0 4.26.86 5.82 2.42a8.225 8.225 0 0 1 2.41 5.83c0 4.54-3.7 8.23-8.24 8.23-1.48 0-2.93-.39-4.19-1.15l-.3-.17-3.12.82.83-3.04-.2-.32a8.188 8.188 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24M8.53 7.33c-.19-.43-.43-.43-.63-.43h-.53c-.2 0-.53.07-.81.38-.28.32-1.07 1.05-1.07 2.57s1.09 2.99 1.24 3.2c.15.22 2.16 3.3 5.23 4.63.75.32 1.33.51 1.79.66.76.24 1.62.21 2.31.12.77-.09 1.9-.78 2.16-1.53.26-.75.26-1.4.19-1.53-.07-.13-.26-.21-.55-.35-.29-.15-1.71-.85-1.97-.94-.26-.1-.45-.15-.64.14-.19.29-.74.94-.9 1.13-.17.19-.34.22-.63.07-.29-.15-1.22-.45-2.32-1.43-.85-.76-1.43-1.7-1.6-1.99-.17-.29-.02-.44.13-.58.13-.13.29-.34.43-.51.15-.17.19-.29.29-.49.1-.19.05-.36-.02-.51-.07-.15-.64-1.54-.88-2.11Z"/></svg>
                                <span>Scrivi su WhatsApp</span>
                                <span class="wa-num">329 781 3392</span>
                            </a>

                            <p class="contact-hint script-font">...per informazioni e prenotazioni</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
	</main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-logo">Barbara Toffano</div>
                <p>&copy; {new Date().getFullYear()} Barbara Toffano. Tutti i diritti riservati.</p>
                <p class="credits">Sito realizzato da <a href="https://bitora.it" target="_blank">Bitora.it</a></p>
            </div>
        </div>
    </footer>
</Layout>

<style>
    /* ── Hero ── */
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 7rem 1.25rem 5rem;
        position: relative;
        overflow: hidden;
    }
    .hero-aurora {
        position: absolute;
        top: 40%; left: 50%;
        transform: translate(-50%, -50%);
        width: min(860px, 100vw);
        height: min(700px, 100vw);
        background:
            radial-gradient(ellipse 60% 55% at 50% 50%, rgba(109,40,217,0.10) 0%, transparent 62%),
            radial-gradient(ellipse 80% 70% at 50% 50%, rgba(185,146,58,0.09) 0%, transparent 72%);
        filter: blur(55px);
        pointer-events: none;
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 760px;
    }
    .hero-eyebrow {
        font-family: 'Cinzel', serif;
        font-size: clamp(0.58rem, 1.8vw, 0.7rem);
        letter-spacing: 5px;
        color: var(--accent);
        text-transform: uppercase;
        margin: 0 0 1.5rem;
    }
    .hero h1 {
        font-size: clamp(2.8rem, 9vw, 6rem);
        font-weight: 400;
        margin: 0 0 0.75rem;
        line-height: 1.05;
        color: var(--text-on-dark);
        text-shadow:
          0 2px 18px rgba(0,0,0,0.45),
          0 1px 0 rgba(0,0,0,0.35);
    }
    .gold-text { color: var(--gold); }
    .subtitle {
        font-size: clamp(1.6rem, 4.5vw, 2.4rem);
        margin: 0 0 2.5rem;
        color: var(--accent);
        opacity: 0.85;
    }
    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* Extra contrast for hero copy over animated backgrounds (mobile only) */
    @media (max-width: 768px) {
        .hero-content {
            padding: 0.25rem 0.75rem;
        }
        .hero-content::before {
            content: '';
            position: absolute;
            inset: -0.75rem -1rem;
            background: radial-gradient(ellipse at 50% 40%, rgba(0,0,0,0.22), rgba(0,0,0,0));
            filter: blur(2px);
            z-index: -1;
            border-radius: 24px;
            pointer-events: none;
        }
    }
    .scroll-hint {
        position: absolute;
        bottom: 2.5rem; left: 50%;
        transform: translateX(-50%);
        z-index: 1;
    }
    .scroll-line {
        width: 1px; height: 50px;
        background: linear-gradient(to bottom, transparent, var(--gold));
        animation: scroll-pulse 2.2s ease-in-out infinite;
    }
    @keyframes scroll-pulse {
        0%,100% { opacity:0.25; transform: scaleY(0.85); }
        50%      { opacity:0.7;  transform: scaleY(1); }
    }

    /* ── CTA Buttons ── */
    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2.4rem;
        background: var(--gold);
        color: #fff;
        border: none;
        text-decoration: none;
        font-family: 'Cinzel', serif;
        font-size: 0.76rem;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        transition: background 0.3s, transform 0.2s;
        border-radius: 3px;
    }
    .cta-button:hover {
        background: var(--gold-mid);
        transform: translateY(-2px);
    }
    .cta-outline {
        background: transparent;
        color: var(--accent);
        border: 1.5px solid rgba(109,40,217,0.45);
        padding: calc(0.9rem - 1.5px) calc(2.4rem - 1.5px);
    }
    .cta-outline:hover {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        transform: translateY(-2px);
    }

    /* ── Animations ── */
    .fade-in        { animation: fadeUp 1.2s ease-out          forwards; opacity: 0; }
    .fade-in-delay  { animation: fadeUp 1.2s ease-out 0.4s     forwards; opacity: 0; }
    .fade-in-delay-2{ animation: fadeUp 1.2s ease-out 0.7s     forwards; opacity: 0; }
    .fade-in-delay-3{ animation: fadeUp 1.2s ease-out 1s       forwards; opacity: 0; }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Ornamental Dividers ── */
    .mystic-divider, .mystic-divider-reverse {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 2rem 0;
        color: rgba(185,146,58,0.4);
        font-size: 0.5rem;
        letter-spacing: 3px;
    }
    .mystic-divider::before,  .mystic-divider::after,
    .mystic-divider-reverse::before, .mystic-divider-reverse::after {
        content: '';
        flex: 1;
        max-width: 200px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(185,146,58,0.3));
    }
    .mystic-divider::after, .mystic-divider-reverse::after {
        background: linear-gradient(270deg, transparent, rgba(185,146,58,0.3));
    }
    .mystic-divider::before { content: '◆ ◆ ◆'; width: auto; flex: none; background: none; font-size: 0.4rem; color: rgba(185,146,58,0.4); }
    .mystic-divider::after  { content: ''; }
    .mystic-divider-reverse::before { content: '◆ ◆ ◆'; width: auto; flex: none; background: none; font-size: 0.4rem; color: rgba(185,146,58,0.4); }
    .mystic-divider-reverse::after  { content: ''; }

    /* ── Sections ── */
    section { padding: 5.5rem 0; position: relative; z-index: 1; }
    h2 {
        text-align: center;
        font-size: clamp(1.6rem, 4.5vw, 2.6rem);
        margin-bottom: 0.5rem;
        letter-spacing: 3px;
    }
    .section-subtitle {
        text-align: center;
        font-size: clamp(1.4rem, 4vw, 2rem);
        color: var(--accent);
        margin-bottom: 3.5rem;
        opacity: 0.8;
    }

    /* ── Services ── */
    .services { background: var(--bg); }
    .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.75rem;
    }

    /* ── Shop Section ── */
    .shop-section { background: var(--bg-2); }
    .shop-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.75rem;
    }
    .shop-cta-row {
        text-align: center;
        margin-top: 3rem;
    }

    /* ── About ── */
    .about { background: var(--bg); }
    .about-card {
        display: grid;
        grid-template-columns: 1fr 240px;
        gap: 3.5rem;
        align-items: center;
        background: var(--card-bg, #fffcf5);
        border: 1px solid rgba(185,146,58,0.20);
        border-left: 4px solid var(--gold);
        border-radius: 16px;
        padding: 3rem 3rem 3rem 2.5rem;
        box-shadow: 0 4px 32px rgba(185,146,58,0.07);
    }
    .about-intro {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        color: var(--gold);
        margin-bottom: 1.25rem;
        line-height: 1.2;
    }
    .about-text p {
        font-size: 1.08rem;
        line-height: 1.85;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
    }
    .about-actions { margin-top: 1.5rem; }
    .yt-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: #cc0000;
        color: white;
        padding: 0.85rem 1.75rem;
        border-radius: 50px;
        text-decoration: none;
        font-family: 'Cinzel', serif;
        font-size: 0.78rem;
        letter-spacing: 1px;
        transition: all 0.3s;
        box-shadow: 0 4px 18px rgba(0,0,0,0.15);
    }
    .yt-btn:hover { background: #e60000; transform: translateY(-2px); }
    .about-visual {
        width: 240px; height: 240px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        flex-shrink: 0;
    }
    .orb-ring {
        position: absolute; inset: 0;
        border: 1.5px dashed rgba(185,146,58,0.32);
        border-radius: 50%;
        animation: spin 28s linear infinite;
    }
    .orb-ring-2 {
        position: absolute;
        inset: 18px;
        border: 1px solid rgba(109,40,217,0.20);
        border-radius: 50%;
        animation: spin 18s linear infinite reverse;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .orb-inner {
        font-size: 5.5rem;
        animation: float 7s ease-in-out infinite;
        filter: drop-shadow(0 4px 20px rgba(109,40,217,0.22));
        position: relative;
        z-index: 1;
    }
    @keyframes float {
        0%,100% { transform: translateY(0); }
        50%      { transform: translateY(-14px); }
    }

    /* ── Contact ── */
    .contact { background: var(--bg-2); }
    .contact-wrap {
        display: flex;
        justify-content: center;
    }
    .contact-altar {
        max-width: 980px;
        width: 100%;
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 2.25rem;
        align-items: center;
        background:
          linear-gradient(135deg, rgba(124,58,237,0.14) 0%, rgba(0,0,0,0) 40%),
          linear-gradient(225deg, rgba(234,88,12,0.10) 0%, rgba(0,0,0,0) 45%),
          rgba(255, 248, 240, 0.92);
        border-radius: 26px;
        padding: 2.75rem 2.5rem;
        border: 1px solid rgba(139, 90, 43, 0.28);
        box-shadow: 0 26px 90px rgba(0,0,0,0.30);
        position: relative;
        overflow: hidden;
    }
    .contact-altar::before {
        content: '';
        position: absolute;
        inset: 10px;
        border-radius: 18px;
        border: 1px solid rgba(124, 58, 237, 0.18);
        pointer-events: none;
    }
    .altar-corner {
        position: absolute;
        color: rgba(234, 88, 12, 0.30);
        letter-spacing: 6px;
        font-size: 0.9rem;
        pointer-events: none;
    }
    .altar-corner.c1 { top: 14px; left: 18px; }
    .altar-corner.c2 { top: 14px; right: 18px; }
    .altar-corner.c3 { bottom: 14px; left: 18px; }
    .altar-corner.c4 { bottom: 14px; right: 18px; }

    .altar-left { text-align: center; }
    .avatar-ring {
        width: 128px;
        height: 128px;
        margin: 0 auto 1.2rem;
        border-radius: 50%;
        display: grid;
        place-items: center;
        position: relative;
        padding: 2px;
        overflow: hidden;
        isolation: isolate;
    }
    .avatar-ring::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background:
          conic-gradient(from 140deg, rgba(234,88,12,0.85), rgba(124,58,237,0.85), rgba(139,90,43,0.85), rgba(234,88,12,0.85));
        animation: ring-spin 14s linear infinite;
        z-index: 0;
    }
    @keyframes ring-spin { to { transform: rotate(360deg); } }
    .avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 6px solid rgba(255, 248, 240, 0.95);
        box-shadow: 0 10px 34px rgba(0,0,0,0.18);
        position: relative;
        z-index: 1;
    }
    .altar-name {
        font-family: 'Cinzel', serif;
        letter-spacing: 3px;
        font-size: 1.05rem;
        color: var(--accent-dark);
        text-transform: uppercase;
    }
    .altar-sub {
        font-size: 1.6rem;
        color: var(--accent);
        opacity: 0.9;
        margin-top: 0.35rem;
    }
    .badge-row {
        display: flex;
        justify-content: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 1.15rem;
    }
    .meta-badge {
        font-family: 'Cinzel', serif;
        font-style: normal;
        font-size: 0.62rem;
        letter-spacing: 1.6px;
        text-transform: uppercase;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: rgba(124,58,237,0.10);
        border: 1px solid rgba(124,58,237,0.22);
        color: rgba(46,16,101,0.85);
        white-space: nowrap;
    }
    .meta-badge-2 {
        background: rgba(234,88,12,0.10);
        border-color: rgba(234,88,12,0.22);
        color: rgba(61,36,16,0.85);
    }

    .altar-right { text-align: left; }
    .contact-desc {
        font-size: 1.02rem;
        color: rgba(42, 24, 48, 0.76);
        line-height: 1.8;
        margin: 0 0 1.25rem;
    }
    .wa-btn.wa-btn-altar {
        width: 100%;
        justify-content: space-between;
        background: linear-gradient(135deg, var(--ember), rgba(124,58,237,0.86));
        box-shadow: 0 16px 55px rgba(234,88,12,0.22);
        padding: 1rem 1.25rem;
    }
    .wa-btn.wa-btn-altar:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 70px rgba(124,58,237,0.22);
        filter: saturate(1.05);
    }
    .wa-btn .wa-num {
        font-family: 'Cinzel', serif;
        font-style: normal;
        font-size: 0.95rem;
        letter-spacing: 1px;
