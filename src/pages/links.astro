          <span>Instagram</span>
        </a>

        <a
          href="/"
          class="link-btn website"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span>Sito ufficiale</span>
        </a>

      </div>
    </div>
  </div>
</Layout>

<style>
  .links-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .links-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 420px;
  }

  .avatar-wrap {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, #c8a97e, #7b3fa0, #c8a97e);
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #12081f;
  }

  .name {
    font-family: 'Cinzel', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #c8a97e;
    margin: 0;
    text-align: center;
    text-shadow: 0 0 20px rgba(200, 169, 126, 0.4);
  }

  .tagline {
    font-family: 'Lora', serif;
    font-style: italic;
    color: rgba(200, 169, 126, 0.7);
    margin: 0;
    font-size: 0.95rem;
    text-align: center;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  .link-btn {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1.4rem;
    border-radius: 50px;
    text-decoration: none;
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
  }

  .link-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.06);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .link-btn:hover::before {
    opacity: 1;
  }

  .link-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.35);
    filter: brightness(1.08);
  }

  .link-btn:active {
    transform: translateY(0);
  }

  .icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .link-btn span {
    flex: 1;
    text-align: center;
    margin-right: 22px; /* compensate icon width so text is visually centered */
  }

  /* YouTube — red */
  .youtube {
    background: linear-gradient(135deg, #1a0a0a 0%, #2a0808 100%);
    color: #ff4e45;
    box-shadow: 0 4px 16px rgba(255, 78, 69, 0.2);
  }

  /* WhatsApp — green */
  .whatsapp {
    background: linear-gradient(135deg, #071a0c 0%, #0a2a10 100%);
    color: #25d366;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.2);
  }

  /* Instagram — pink/purple */
  .instagram {
    background: linear-gradient(135deg, #1a0a18 0%, #2a0a22 100%);
    color: #e1306c;
    box-shadow: 0 4px 16px rgba(225, 48, 108, 0.2);
  }

  /* Website — gold */
  .website {
    background: linear-gradient(135deg, #1a130a 0%, #2a1e0a 100%);
    color: #c8a97e;
    box-shadow: 0 4px 16px rgba(200, 169, 126, 0.2);
  }
</style>
