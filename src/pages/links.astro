---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Barbara Toffano | I miei link"
  description="Tutti i link di Barbara Toffano: YouTube, WhatsApp, Instagram e molto altro."
  noindex={true}
>
  <div class="links-page">
    <div class="links-container">
      <div class="avatar-wrap">
        <img src="/logo.jpeg" alt="Barbara Toffano" class="avatar" />
      </div>
      <h1 class="name">Barbara Toffano</h1>
      <p class="tagline">Tarologia · Magia · ThetaHealing</p>

      <div class="links-list">

        <a
          href="https://www.youtube.com/@Barbara_toffano"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn youtube"
        >
