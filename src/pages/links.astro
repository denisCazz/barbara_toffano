          </svg>
          <span>YouTube</span>
        </a>

        <a
          href="https://wa.me/393297813392"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn whatsapp"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97s-.47-.15-.67.15-.77.97-.94 1.17-.35.22-.65.07a8.18 8.18 0 0 1-2.4-1.48 9.02 9.02 0 0 1-1.66-2.07c-.17-.3 0-.46.13-.6s.3-.35.44-.52a2 2 0 0 0 .3-.5.55.55 0 0 0-.02-.52c-.07-.15-.67-1.61-.91-2.2-.24-.58-.48-.5-.67-.51h-.57a1.1 1.1 0 0 0-.8.37 3.35 3.35 0 0 0-1.04 2.5 5.82 5.82 0 0 0 1.22 3.08c.15.2 2.1 3.2 5.08 4.49a17.2 17.2 0 0 0 1.7.62 4.08 4.08 0 0 0 1.87.12c.57-.09 1.76-.72 2-1.41s.24-1.29.17-1.41-.27-.22-.57-.37zM12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37A9.86 9.86 0 0 1 2.14 12 9.91 9.91 0 0 1 12.06 2.1 9.91 9.91 0 0 1 22 12a9.92 9.92 0 0 1-9.95 9.8zM12.05 0A11.93 11.93 0 0 0 .08 12a11.9 11.9 0 0 0 1.6 5.98L0 24l6.2-1.63A11.93 11.93 0 0 0 24 12 11.93 11.93 0 0 0 12.05 0z"/>
          </svg>
          <span>WhatsApp</span>
        </a>

        <a
          href="https://www.instagram.com/barbaratoffanoelesuemagiche"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn instagram"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
